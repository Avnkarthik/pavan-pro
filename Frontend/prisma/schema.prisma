datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  password String
  name     String?
}

// Structures: Contains only PDF links
model Structure {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  driveLink   String?   // Google Drive Link
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 3D Images: Contains only Drive links (formerly videos)
model ThreeDImage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  driveLink   String?   // Google Drive Link
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Plans: Contains only PDF links (distinct from Structures)
model Plan {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  driveLink   String?   // Google Drive Link
  category    String?  // e.g., "Foundation", "Elevation", "Layout"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Aim {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  content     String
  updatedAt   DateTime @updatedAt
}

model About {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  content     String
  imageUrl    String?
  updatedAt   DateTime @updatedAt
}
